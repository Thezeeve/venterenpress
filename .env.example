CURRENTS_API_KEY=""
THENEWSAPI_API_TOKEN=""
ALPHA_VANTAGE_API_KEY=""
FINNHUB_API_KEY=""
COINGECKO_API_KEY=""

# Authentication
GOOGLE_CLIENT_ID="replace-me"
GOOGLE_CLIENT_SECRET="replace-me"
AUTH_TRUST_HOST="true"
TWO_FACTOR_ISSUER="Global Press Network"

# Storage
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="vanterenpress-media"
S3_ACCESS_KEY_ID="R2_ACCESS_KEY_ID"
S3_SECRET_ACCESS_KEY="R2_SECRET_ACCESS_KEY"
S3_PUBLIC_BASE_URL="https://PUBLIC_R2_URL_OR_CUSTOM_DOMAIN"
S3_FORCE_PATH_STYLE="false"
CDN_BASE_URL=""

# Email and newsletters
EMAIL_PROVIDER="SMTP"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Global Press Network <no-reply@globalpress.network>"
RESEND_API_KEY=""

# Payments and subscriptions
PAYMENT_PROVIDER="MOCK"
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
FREE_ARTICLE_LIMIT="5"
PAYWALL_PREMIUM_LABEL="Premium"

# AI and search
AI_PROVIDER="MOCK"
OPENAI_API_KEY=""
SEARCH_PROVIDER="POSTGRES"
MEILISEARCH_URL=""
