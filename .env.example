# Core app
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="https://vanterenpress.org"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
SITE_NAME="Global Press Network"
SITE_SUPPORT_EMAIL="support@globalpress.network"
DEFAULT_LOCALE="en"
LOG_LEVEL="info"

# Database
DATABASE_URL="postgresql://neondb_owner:npg_sI0w2keMVqxt@ep-crimson-sound-ah0066p7-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
