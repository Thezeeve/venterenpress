generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  EDITOR_IN_CHIEF
  MANAGING_EDITOR
  JOURNALIST
  FACT_CHECKER
  CONTRIBUTOR
  SUBSCRIBER
  GUEST_READER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  ARCHIVED
}

enum ArticleStatus {
  DRAFT
  SUBMITTED
  FACT_CHECKING
  EDITOR_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ArticleType {
  NEWS
  ANALYSIS
  OPINION
  EDITORIAL
  LIVE_BLOG
  VIDEO
  PODCAST
  INVESTIGATION
  SPONSORED
}

enum AccessTier {
  FREE
  PREMIUM
  MEMBERS_ONLY
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  GALLERY
  LIVE_STREAM
  GRAPHIC
  AUTHOR_PHOTO
  PODCAST_COVER
}

enum MediaProcessingStatus {
  PENDING
  READY
  FAILED
}

enum EditionCode {
  UNITED_STATES
  UNITED_KINGDOM
  CANADA
  EUROPE
  AFRICA
  ASIA
  MIDDLE_EAST
  LATIN_AMERICA
}

enum AssignmentStatus {
  PITCHED
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum WorkflowDecision {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum NotificationType {
  ASSIGNMENT
  COMMENT
  APPROVAL
  BREAKING_ALERT
  SYSTEM
  NEWSLETTER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  MANUAL
  MOCK
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
}

enum NewsletterSubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum WorkflowCommentVisibility {
  INTERNAL
  FACT_CHECK_ONLY
  EDITORIAL
}

enum SearchProvider {
  POSTGRES
  MEILISEARCH
  TYPESENSE
  ELASTICSEARCH
}

enum LanguageCode {
  ENGLISH
  FRENCH
  SPANISH
  GERMAN
  ARABIC
  CHINESE
  PORTUGUESE
  HINDI
}

enum GlobalRegion {
  AMERICAS
  EUROPE
  AFRICA
  MIDDLE_EAST
  ASIA_PACIFIC
}

enum AIJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CredibilityLevel {
  LOW
  MEDIUM
  HIGH
  VERIFIED
}

enum SyndicationStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum DistributionFormat {
  RSS
  JSON
  XML
  API
}

enum VideoPublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  LIVE
  ARCHIVED
}

enum PodcastPublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum MarketplaceListingType {
  SPONSORED_REPORT
  PRESS_RELEASE
  RESEARCH_REPORT
  DATA_PRODUCT
}

enum MarketplaceListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DataProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DataVisualizationType {
  CHART
  MAP
  TIMELINE
  TABLE
  DASHBOARD
}

enum CrisisSeverity {
  WATCH
  ACTIVE
  SEVERE
  RESOLVED
}

enum CrisisStatus {
  MONITORING
  ACTIVE
  STABILIZED
  CLOSED
}

enum HealthStatus {
  OK
  DEGRADED
  OUTAGE
}

enum DeploymentRegion {
  US_EAST
  US_WEST
  EUROPE
  ASIA_PACIFIC
  AFRICA
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  image                 String?
  passwordHash          String?
  role                  Role                   @default(GUEST_READER)
  status                UserStatus             @default(ACTIVE)
  locale                String                 @default("en")
  timezone              String                 @default("UTC")
  bio                   String?                @db.Text
  headline              String?
  contractUrl           String?
  contractNotes         String?                @db.Text
  isVerifiedJournalist   Boolean                @default(false)
  socialLinks           Json?
  notificationPreferences Json?
  newsletterPreferences  Json?
  beats                 String[]
  isTwoFactorEnabled    Boolean                @default(false)
  twoFactorSecret       String?
  lastLoginAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  sessions              Session[]
  authoredArticles      Article[]              @relation("AuthorArticles")
  articleVersions       ArticleVersion[]
  assignments           Assignment[]           @relation("AssigneeAssignments")
  createdAssignments    Assignment[]           @relation("CreatorAssignments")
  articleAutosaves      ArticleAutosave[]
  comments              Comment[]
  workflowComments      WorkflowComment[]
  assignmentComments    AssignmentComment[]
  bookmarks             Bookmark[]
  notes                 ResearchNote[]
  uploadedMedia         MediaAsset[]           @relation("UploadedMedia")
  followedBy            Follow[]               @relation("FollowedJournalist")
  following             Follow[]               @relation("Follower")
  notifications         Notification[]
  auditLogs             AuditLog[]
  subscriptions         Subscription[]
  paymentCustomers      PaymentCustomer[]
  paymentTransactions   PaymentTransaction[]
  newsletterCampaigns   NewsletterCampaign[]   @relation("CampaignAuthor")
  approvals             WorkflowStep[]         @relation("ApproverWorkflow")
  accessEvents          ReaderAccessEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Edition {
  id                 String               @id @default(cuid())
  code               EditionCode          @unique
  name               String
  region             String
  locale             String
  description        String?
  heroLabel          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  articles           Article[]
  regionalBlocks     RegionalBlock[]
  newsletterSegments NewsletterSegment[]
  breakingBanners    BreakingNewsBanner[]
}

model Category {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String            @unique
  description String?
  isBreaking  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  articles    ArticleCategory[]
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  articles  ArticleTag[]
}

model Article {
  id                   String              @id @default(cuid())
  slug                 String              @unique
  title                String
  dek                  String?
  body                 Json
  excerpt              String?             @db.Text
  seoTitle             String?
  seoDescription       String?             @db.Text
  seoKeywords          String[]
  premiumPreview       String?             @db.Text
  updatedOn            DateTime?
  correctionNotice     String?             @db.Text
  correctionIssuedAt   DateTime?
  status               ArticleStatus       @default(DRAFT)
  articleType          ArticleType         @default(NEWS)
  accessTier           AccessTier          @default(FREE)
  featured             Boolean             @default(false)
  breaking             Boolean             @default(false)
  allowComments        Boolean             @default(true)
  scheduledFor         DateTime?
  submittedAt          DateTime?
  approvedAt           DateTime?
  publishedAt          DateTime?
  archivedAt           DateTime?
  deletedAt            DateTime?
  readingTimeMinutes   Int                 @default(4)
  featuredImageUrl     String?
  featuredImageAlt     String?
  videoUrl             String?
  audioUrl             String?
  canonicalUrl         String?
  moderationScore      Float?
  aiSummary            String?             @db.Text
  aiHeadlineOptions    String[]
  aiSeoSuggestions     String[]
  duplicateRiskScore   Float?
  translationLocales   String[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  authorId             String
  editionId            String
  author               User                @relation("AuthorArticles", fields: [authorId], references: [id])
  edition              Edition             @relation(fields: [editionId], references: [id])
  categories           ArticleCategory[]
  tags                 ArticleTag[]
  citations            Citation[]
  versions             ArticleVersion[]
  autosaves            ArticleAutosave[]
  media                MediaAsset[]
  comments             Comment[]
  workflowComments     WorkflowComment[]
  bookmarks            Bookmark[]
  assignments          Assignment[]
  workflowSteps        WorkflowStep[]
  analyticsSnapshots   AnalyticsSnapshot[]
  accessEvents         ReaderAccessEvent[]
  liveUpdates          LiveUpdate[]
  newsletterCampaigns  NewsletterCampaign[]
  sponsoredContent     SponsoredContent?

  @@index([status, publishedAt])
  @@index([editionId, publishedAt])
  @@index([articleType, status])
  @@index([deletedAt])
}

model ArticleCategory {
  articleId  String
  categoryId String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model ArticleVersion {
  id          String   @id @default(cuid())
  articleId   String
  authorId    String
  version     Int
  title       String
  excerpt     String?  @db.Text
  body        Json
  status      ArticleStatus
  changelog   String?
  createdAt   DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])

  @@unique([articleId, version])
}

model ArticleAutosave {
  id        String   @id @default(cuid())
  articleId String
  userId    String
  title     String
  excerpt   String?  @db.Text
  body      Json
  savedAt   DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId, savedAt])
}

model Citation {
  id          String   @id @default(cuid())
  articleId   String
  sourceName  String
  sourceUrl   String
  quote       String?
  sourceType  String
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id               String                @id @default(cuid())
  articleId        String?
  uploaderId       String?
  title            String
  altText          String?
  bucket           String
  objectKey        String
  url              String
  thumbnailUrl     String?
  type             MediaType
  mimeType         String
  sizeBytes        Int
  width            Int?
  height           Int?
  blurDataUrl      String?
  durationSec      Int?
  metadata         Json?
  processingStatus MediaProcessingStatus @default(PENDING)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  article          Article?              @relation(fields: [articleId], references: [id], onDelete: SetNull)
  uploader         User?                 @relation("UploadedMedia", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@unique([bucket, objectKey])
}

model Assignment {
  id               String              @id @default(cuid())
  title            String
  brief            String              @db.Text
  dueAt            DateTime?
  status           AssignmentStatus    @default(ASSIGNED)
  articleId        String?
  assigneeId       String
  createdById      String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  article          Article?            @relation(fields: [articleId], references: [id], onDelete: SetNull)
  assignee         User                @relation("AssigneeAssignments", fields: [assigneeId], references: [id])
  createdBy        User                @relation("CreatorAssignments", fields: [createdById], references: [id])
  comments         AssignmentComment[]
}

model AssignmentComment {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkflowStep {
  id          String           @id @default(cuid())
  articleId   String
  role        Role
  approverId  String?
  decision    WorkflowDecision @default(PENDING)
  notes       String?          @db.Text
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  article     Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  approver    User?            @relation("ApproverWorkflow", fields: [approverId], references: [id])
}

model WorkflowComment {
  id         String                    @id @default(cuid())
  articleId  String
  userId     String
  body       String                    @db.Text
  visibility WorkflowCommentVisibility @default(INTERNAL)
  createdAt  DateTime                  @default(now())
  article    Article                   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String    @id @default(cuid())
  articleId   String
  userId      String
  parentId    String?
  body        String    @db.Text
  upvotes     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies     Comment[] @relation("CommentReplies")
}

model Bookmark {
  userId     String
  articleId  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([userId, articleId])
}

model Follow {
  followerId   String
  journalistId String
  createdAt    DateTime @default(now())
  follower     User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  journalist   User     @relation("FollowedJournalist", fields: [journalistId], references: [id], onDelete: Cascade)

  @@id([followerId, journalistId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  title      String
  body       String           @db.Text
  type       NotificationType
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResearchNote {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String   @db.Text
  tags       String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id                String         @id @default(cuid())
  slug              String         @unique
  name              String
  description       String?
  priceMonthly      Decimal        @db.Decimal(10, 2)
  priceYearly       Decimal        @db.Decimal(10, 2)
  currency          String         @default("USD")
  freeArticleLimit  Int            @default(5)
  features          String[]
  provider          PaymentProvider @default(MOCK)
  providerProductRef String?
  providerPriceRef   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subscriptions     Subscription[]
  payments          PaymentTransaction[]
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String
  planId        String
  status        SubscriptionStatus @default(TRIALING)
  startedAt     DateTime           @default(now())
  renewsAt      DateTime?
  canceledAt    DateTime?
  providerRef   String?
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan   @relation(fields: [planId], references: [id])
}

model PaymentCustomer {
  id                  String          @id @default(cuid())
  userId              String
  provider            PaymentProvider
  providerCustomerRef String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerCustomerRef])
}

model PaymentTransaction {
  id                String                   @id @default(cuid())
  userId            String
  planId            String?
  provider          PaymentProvider
  providerReference String?
  amount            Decimal                  @db.Decimal(10, 2)
  currency          String                   @default("USD")
  status            PaymentTransactionStatus @default(PENDING)
  metadata          Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
}

model AdvertisementSlot {
  id          String   @id @default(cuid())
  name        String   @unique
  location    String
  dimensions  String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SponsoredContent {
  id               String   @id @default(cuid())
  articleId        String   @unique
  sponsorName      String
  callToActionUrl  String
  disclosureLabel  String   @default("Sponsored")
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model AnalyticsSnapshot {
  id               String   @id @default(cuid())
  articleId        String
  views            Int      @default(0)
  uniqueVisitors   Int      @default(0)
  averageReadTime  Int      @default(0)
  bounceRate       Float    @default(0)
  conversions      Int      @default(0)
  capturedAt       DateTime @default(now())
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model ReaderAccessEvent {
  id         String   @id @default(cuid())
  articleId  String
  userId     String?
  sessionId  String
  viewedAt   DateTime @default(now())
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, viewedAt])
}

model SearchDocument {
  id         String         @id @default(cuid())
  entityType String
  entityId   String
  provider   SearchProvider @default(POSTGRES)
  title      String
  excerpt    String?
  content    String         @db.Text
  filters    Json?
  updatedAt  DateTime       @updatedAt
  createdAt  DateTime       @default(now())

  @@unique([entityType, entityId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RegionalBlock {
  id          String   @id @default(cuid())
  editionId   String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  edition     Edition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
}

model LiveUpdate {
  id          String   @id @default(cuid())
  articleId   String
  title       String
  body        String   @db.Text
  publishedAt DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model BreakingNewsBanner {
  id          String    @id @default(cuid())
  editionId   String?
  title       String
  summary     String?
  linkUrl     String?
  isActive    Boolean   @default(true)
  priority    Int       @default(0)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  edition     Edition?  @relation(fields: [editionId], references: [id], onDelete: SetNull)
}

model NewsletterSegment {
  id          String                 @id @default(cuid())
  editionId   String?
  slug        String                 @unique
  name        String
  description String?
  regions     String[]
  topics      String[]
  status      NewsletterSubscriberStatus @default(ACTIVE)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  edition     Edition?               @relation(fields: [editionId], references: [id], onDelete: SetNull)
  campaigns   NewsletterCampaign[]
}

model NewsletterSubscriber {
  id          String                     @id @default(cuid())
  email       String                     @unique
  name        String?
  status      NewsletterSubscriberStatus @default(ACTIVE)
  topics      String[]
  regions     String[]
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
}

model NewsletterCampaign {
  id            String           @id @default(cuid())
  articleId     String?
  segmentId     String?
  createdById   String
  title         String
  subject       String
  preheader     String?
  bodyHtml      String           @db.Text
  status        NewsletterStatus @default(DRAFT)
  scheduledFor  DateTime?
  sentAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  article       Article?         @relation(fields: [articleId], references: [id], onDelete: SetNull)
  segment       NewsletterSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  createdBy     User             @relation("CampaignAuthor", fields: [createdById], references: [id])
}

model AIResearchSession {
  id                 String       @id @default(cuid())
  articleId          String?
  userId             String?
  topic              String
  query              String       @db.Text
  status             AIJobStatus   @default(PENDING)
  sourceCount        Int           @default(0)
  verificationScore  Float         @default(0)
  contradictionCount Int           @default(0)
  notes              String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  sources            AIResearchSource[]
  findings           AIResearchFinding[]
}

model AIResearchSource {
  id             String          @id @default(cuid())
  sessionId      String
  title          String
  url            String
  publisher      String?
  credibility    CredibilityLevel @default(MEDIUM)
  isContradictory Boolean         @default(false)
  summary        String?         @db.Text
  score          Float           @default(0)
  createdAt      DateTime        @default(now())
  session        AIResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AIResearchFinding {
  id             String       @id @default(cuid())
  sessionId      String
  title          String
  body           String       @db.Text
  category       String
  importance     Int          @default(0)
  createdAt      DateTime     @default(now())
  session        AIResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AIWritingSuggestion {
  id             String        @id @default(cuid())
  articleId      String?
  userId         String?
  suggestionType String
  language       LanguageCode  @default(ENGLISH)
  title          String
  body           String        @db.Text
  confidence     Float         @default(0)
  createdAt      DateTime      @default(now())
}

model AIContentInsight {
  id               String   @id @default(cuid())
  articleId        String?
  relatedArticleId String?
  insightType      String
  title            String
  description      String   @db.Text
  score            Float    @default(0)
  createdAt        DateTime @default(now())
}

model TranslationJob {
  id             String       @id @default(cuid())
  articleId      String?
  sourceLanguage LanguageCode
  targetLanguage LanguageCode
  status         AIJobStatus  @default(PENDING)
  translatedTitle String?
  translatedExcerpt String?   @db.Text
  translatedBody String?      @db.Text
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
}

model Organization {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  plan         String
  seats        Int      @default(1)
  regions      GlobalRegion[]
  languages    LanguageCode[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SyndicationPartner {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  website      String?
  status       SyndicationStatus  @default(DRAFT)
  regions      GlobalRegion[]
  languages    LanguageCode[]
  apiKeyPrefix String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  feeds        SyndicationFeed[]
}

model SyndicationFeed {
  id           String             @id @default(cuid())
  partnerId    String?
  slug         String             @unique
  title        String
  format       DistributionFormat @default(JSON)
  isPublic     Boolean            @default(false)
  regions      GlobalRegion[]
  languages    LanguageCode[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  partner      SyndicationPartner? @relation(fields: [partnerId], references: [id])
}

model SyndicationLicense {
  id          String   @id @default(cuid())
  articleId   String?
  partnerId   String?
  terms       String   @db.Text
  status      SyndicationStatus @default(DRAFT)
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VideoChannel {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VideoProgram {
  id           String               @id @default(cuid())
  channelId    String?
  slug         String   @unique
  title        String
  description  String?
  status       VideoPublicationStatus @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  durationSec  Int      @default(0)
  liveUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PodcastShow {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  coverUrl    String?
  status      PodcastPublicationStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PodcastEpisode {
  id          String   @id @default(cuid())
  showId      String?
  slug        String   @unique
  title       String
  description String?
  audioUrl    String
  videoUrl    String?
  durationSec Int      @default(0)
  status      PodcastPublicationStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Advertiser {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  contactEmail String?
  website     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdCampaign {
  id          String           @id @default(cuid())
  advertiserId String?
  title       String
  status      AdCampaignStatus @default(DRAFT)
  startsAt    DateTime?
  endsAt      DateTime?
  budget      Decimal          @db.Decimal(12, 2)
  impressions Int              @default(0)
  clicks      Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model AdPlacement {
  id         String   @id @default(cuid())
  name       String   @unique
  page       String
  size       String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MarketplaceListing {
  id          String                @id @default(cuid())
  slug        String                @unique
  title       String
  type        MarketplaceListingType
  status      MarketplaceListingStatus @default(DRAFT)
  description String?               @db.Text
  price       Decimal               @db.Decimal(12, 2)
  currency    String                @default("USD")
  authorId    String?
  articleId   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model DataProject {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  type        DataVisualizationType @default(DASHBOARD)
  status      DataProjectStatus  @default(DRAFT)
  description String?           @db.Text
  sourceUrl   String?
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  visuals     DataVisualization[]
}

model DataVisualization {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  chartType   DataVisualizationType
  config      Json
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     DataProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Bureau {
  id          String   @id @default(cuid())
  slug        String   @unique
  country     String
  city        String
  region      GlobalRegion
  leadEditorId String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BureauAssignment {
  id          String       @id @default(cuid())
  bureauId    String?
  userId      String?
  title       String
  description String?      @db.Text
  dueAt       DateTime?
  status      AssignmentStatus @default(ASSIGNED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CrisisEvent {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  severity    CrisisSeverity @default(WATCH)
  status      CrisisStatus   @default(MONITORING)
  description String?      @db.Text
  startedAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  updates     CrisisUpdate[]
}

model CrisisUpdate {
  id          String   @id @default(cuid())
  crisisEventId String
  articleId   String?
  title       String
  body        String   @db.Text
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  crisisEvent CrisisEvent @relation(fields: [crisisEventId], references: [id], onDelete: Cascade)
}

model PlatformHealthSnapshot {
  id             String       @id @default(cuid())
  region         DeploymentRegion
  status         HealthStatus @default(OK)
  apiLatencyMs    Int         @default(0)
  errorRate      Float       @default(0)
  queueDepth     Int         @default(0)
  audienceRequests Int        @default(0)
  revenueCents   Int         @default(0)
  capturedAt     DateTime    @default(now())
}

model DisasterRecoveryPlan {
  id          String   @id @default(cuid())
  name        String
  rpoMinutes  Int      @default(60)
  rtoMinutes  Int      @default(120)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  key        String   @id
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
